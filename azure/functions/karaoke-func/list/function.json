{
  "bindings": [
    {
      "authLevel": "anonymous",           // or "function"
      "type": "httpTrigger",
      "direction": "in",
      "name": "req",
      "methods": [ "get", "options" ],
      "route": "list"
    },
    {
      "type": "http",
      "direction": "out",
      "name": "$return"
    }
  ],
  "scriptFile": "init.py"
}